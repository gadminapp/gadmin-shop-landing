---
import logoBg from '@/assets/img/logo-dark.webp'
import Icon from '@/shared/components/Icon.astro'
import { Image } from 'astro:assets'

interface Props {
  isFixed?: boolean
}

const { isFixed = true } = Astro.props
---

<nav class:list=`nav ${isFixed ? 'nav--fixed' : ''}` transition:persist>
  <div class='wrapper nav-wrapper' data-aos='zoom-in'>
    <a href='/' class='nav-logo'>
      <Image src={logoBg} width={32} height={32} alt='Logo de Gadmin' loading='eager' />
      <p class='nav-logo-title'>Gadmin Shop</p>
    </a>
    <div class='nav-buttons'>
      <a href='/#how-it-works' class='nav-link hide-on-mobile'> Cómo funciona </a>
      <a href='/#faq' class='nav-link hide-on-mobile'> Preguntas </a>
      <a href='/#pricing' class='nav-cta-btn cta--track' id='nav-cta-btn'>
        <span class='nav-cta-lock'>
          <Icon name='lock-closed' color='var(--dark)' size={14} />
        </span>{' '}
        Preventa
      </a>
    </div>
  </div>
</nav>

<script>
  const preventaBtn = document.getElementById('nav-cta-btn')

  if (preventaBtn) {
    preventaBtn.addEventListener('click', () => {
      // @ts-ignore
      if (typeof seline !== 'undefined') {
        // @ts-ignore
        seline.track('Shop Landing: Preventa Click')
      }
    })
  }
</script>

<style>
  .nav {
    width: 100%;
    background-color: transparent;
    transition: 0.2s ease background-color;
    z-index: 100;
  }

  .nav--fixed {
    position: fixed;
    top: 0;
    left: 0;
  }

  .nav:not(.nav--fixed),
  body.scrolled .nav {
    background-color: rgba(45, 51, 57, 0.8);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow: 0 4px 24px 0 rgba(0, 0, 0, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
  }

  .nav-buttons {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    text-decoration: none;
  }

  .nav-logo-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--primary);
  }

  .nav-logo-sub {
    font-weight: 400;
    color: var(--accent);
    font-size: 0.9rem;
  }

  .nav-link {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--white);
  }

  .nav-link:visited {
    color: rgba(255, 255, 255, 0.65);
  }

  .nav-link:visited:hover {
    color: var(--white);
  }

  .nav-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 1.1rem;
    border-radius: 0.5rem;
    background: var(--primary);
    color: var(--dark) !important;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .nav-cta-btn:hover {
    background: var(--primary-lighter);
    box-shadow: 0 4px 12px rgba(255, 178, 0, 0.3);
  }

  .nav-cta-btn:visited {
    color: var(--white);
  }

  .nav-cta-lock {
    display: flex;
  }

  @media screen and (max-width: 768px) {
    .nav-wrapper {
      padding: 0.6rem 0.75rem;
    }

    .nav-cta-btn {
      font-size: 0.8rem;
      padding: 0.45rem 0.85rem;
    }
  }
</style>
